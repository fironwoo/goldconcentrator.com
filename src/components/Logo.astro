---
interface Props {
  light?: boolean;
}

const { light = false } = Astro.props;
---

<a class:list={['logo', { 'logo--light': light }]} href="/" aria-label="Gold Concentrator home">
  <svg viewBox="0 0 48 48" aria-hidden="true">
    <path d="M24 3 42 13v22L24 45 6 35V13L24 3Z"></path>
    <path d="M24 10 35 16v13L24 36 13 29V16l11-6Z"></path>
    <path d="M18 17h12l-2 5H20l-2-5Zm2 8h8l-4 6-4-6Z"></path>
  </svg>
  <span>
    <strong>Gold</strong>
    <small>Concentrator</small>
  </span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
  }

  svg {
    width: 38px;
    height: 38px;
    fill: none;
    stroke: var(--gold);
    stroke-linejoin: round;
    stroke-width: 2;
  }

  span {
    display: grid;
    line-height: 0.9;
    text-transform: uppercase;
  }

  strong {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: 0.04em;
  }

  small {
    margin-top: 5px;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.18em;
  }

  .logo--light {
    color: var(--white);
  }
</style>
