---
interface Props {
  title?: string;
  text?: string;
}

const {
  title = 'Start with the ore, not a machine list.',
  text = 'Share the mineral, target capacity and what you already know about the feed. We will review the project within one business day.',
} = Astro.props;
---

<section class="cta">
  <div class="container cta-inner">
    <div>
      <span class="eyebrow">Project review</span>
      <h2>{title}</h2>
      <p>{text}</p>
    </div>
    <a class="button" href="/assess-my-project/">Assess My Project</a>
  </div>
</section>

<style>
  .cta {
    overflow: hidden;
    padding: 72px 0;
    color: var(--white);
    background:
      linear-gradient(120deg, rgba(182, 111, 50, 0.22), transparent 45%),
      var(--charcoal);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 50px;
  }

  h2 {
    max-width: 760px;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.7rem, 6vw, 5.2rem);
    line-height: 0.95;
    text-transform: uppercase;
  }

  p {
    max-width: 650px;
    margin: 20px 0 0;
    color: rgba(255, 253, 248, 0.68);
  }

  @media (max-width: 760px) {
    .cta-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
