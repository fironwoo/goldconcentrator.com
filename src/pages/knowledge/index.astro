---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProjectCta from '../../components/ProjectCta.astro';

const articles = (await getCollection('knowledge')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout
  title="Mineral Processing Knowledge & Field Notes"
  description="Practical guidance on gold processing, gravity concentration, flowsheet decisions, plant sizing and avoidable equipment selection errors."
>
  <header class="page-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Knowledge' }]} />
      <span class="eyebrow">Process decisions explained</span>
      <h1>Knowledge</h1>
      <p>
        Clear guidance for mine owners, backed by enough process detail for engineers to examine
        the assumptions.
      </p>
    </div>
  </header>
  <section class="section">
    <div class="container article-grid">
      {articles.map((article) => (
        <article class="surface-card">
          <span class="tag">{article.data.category}</span>
          <time datetime={article.data.publishedAt.toISOString()}>
            {article.data.publishedAt.toLocaleDateString('en', { dateStyle: 'medium' })}
          </time>
          <h2>{article.data.title}</h2>
          <p>{article.data.description}</p>
          <a class="text-link" href={`/knowledge/${article.id}/`}>Read article</a>
        </article>
      ))}
    </div>
  </section>
  <ProjectCta />
</BaseLayout>

<style>
  .article-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  article {
    min-height: 340px;
  }

  time {
    display: block;
    margin-top: 18px;
    color: var(--muted);
    font-size: 0.72rem;
  }

  h2 {
    margin: 28px 0 14px;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 0.98;
    text-transform: uppercase;
  }

  @media (max-width: 700px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
