---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout title="Privacy Policy" description="How Gold Concentrator handles project enquiry data." noindex>
  <header class="page-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Privacy' }]} />
      <h1>Privacy Policy</h1>
      <p>Plain-language handling rules for project enquiries and website analytics.</p>
    </div>
  </header>
  <section class="section">
    <article class="container prose">
      <h2>Information we collect</h2>
      <p>
        The project form collects the technical and contact information you submit. Attachments are
        sent separately through email or WhatsApp and are not uploaded through this website.
      </p>
      <h2>Why we use it</h2>
      <p>
        We use enquiry data only to evaluate, respond to and follow up on the project. We do not sell
        personal data.
      </p>
      <h2>Retention</h2>
      <p>
        Form submissions are delivered by email and stored in a private database for up to 180 days
        as a delivery backup. Records can be removed earlier on a verified request.
      </p>
      <h2>Analytics and anti-spam</h2>
      <p>
        The site uses Cloudflare Web Analytics and Turnstile. It does not install Google Analytics
        or advertising cookies.
      </p>
      <h2>Contact</h2>
      <p>Request access or deletion by emailing inquiry@goldconcentrator.com.</p>
    </article>
  </section>
</BaseLayout>
