---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProjectCta from '../../components/ProjectCta.astro';
import { getWhatsAppUrl, SITE } from '../../lib/site';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  type="article"
  noindex={!entry.data.verified}
>
  <header class="page-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Projects', href: '/projects/' }, { label: entry.data.title }]} />
      <span class="eyebrow">{entry.data.country} / {entry.data.capacity}</span>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
    </div>
  </header>
  <section class="section">
    <div class="container content-shell">
      <article class="prose">
        <ul class="meta-list">
          <li class="tag">{entry.data.mineral}</li>
          <li class="tag">{entry.data.process}</li>
        </ul>
        <blockquote><strong>Evidence status:</strong> {entry.data.evidenceNote}</blockquote>
        <Content />
      </article>
      <aside class="sidebar">
        <span class="eyebrow">Talk to a reviewer</span>
        <h2>Send ore photos and project notes</h2>
        <p>
          If your ore looks similar, send the mineral, target TPH, feed size, country and a few
          photos or short videos. WhatsApp is usually the fastest way to start.
        </p>
        <ul class="review-list">
          <li>Ore photos or videos</li>
          <li>Target capacity and feed size</li>
          <li>Existing equipment or site limits</li>
        </ul>
        <p class="review-note">A real person reviews the project within one business day.</p>
        <div class="project-actions">
          <a class="button" href={getWhatsAppUrl(SITE.whatsapp)}>WhatsApp</a>
          <a class="text-link" href="/assess-my-project/">Use the form</a>
        </div>
      </aside>
    </div>
  </section>
  <ProjectCta />
</BaseLayout>

<style>
  .review-list {
    display: grid;
    gap: 10px;
    margin: 18px 0;
    padding: 0;
    list-style: none;
  }

  .review-list li {
    padding: 9px 0;
    border-top: 1px solid rgba(255, 253, 248, 0.13);
    color: rgba(255, 253, 248, 0.76);
    font-size: 0.86rem;
  }

  .review-note {
    color: var(--gold-light) !important;
    font-weight: 700;
  }

  .project-actions {
    display: grid;
    gap: 12px;
  }
</style>
