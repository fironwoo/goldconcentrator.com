---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProjectCta from '../../components/ProjectCta.astro';
import { getPublicVideos, parseYouTubeVideoId } from '../../lib/videos';

export async function getStaticPaths() {
  const entries = getPublicVideos(await getCollection('videos'));
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const videoId = parseYouTubeVideoId(entry.data.youtubeUrl);
const thumbnail =
  entry.data.coverImage ??
  (videoId ? `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg` : undefined);
const videoSchema = videoId
  ? {
      '@context': 'https://schema.org',
      '@type': 'VideoObject',
      name: entry.data.title,
      description: entry.data.description,
      uploadDate: entry.data.publishedAt.toISOString(),
      thumbnailUrl: thumbnail,
      embedUrl: `https://www.youtube-nocookie.com/embed/${videoId}`,
    }
  : undefined;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.coverImage}
  structuredData={videoSchema}
>
  <header class="page-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Videos', href: '/videos/' }, { label: entry.data.title }]} />
      <span class="eyebrow">{entry.data.mineral}</span>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
    </div>
  </header>

  <section class="section">
    <div class="container content-shell">
      <article class="prose">
        {videoId ? (
          <div class="video-frame">
            <iframe
              src={`https://www.youtube-nocookie.com/embed/${videoId}`}
              title={entry.data.title}
              loading="lazy"
              referrerpolicy="strict-origin-when-cross-origin"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
        ) : (
          <div class="video-fallback">
            <p>This video address cannot be embedded safely.</p>
            <a
              class="button"
              href={entry.data.youtubeUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Open video source
            </a>
          </div>
        )}
        <Content />
      </article>
      <aside class="sidebar">
        <span class="eyebrow">Video context</span>
        <h2>Check the ore and operating conditions.</h2>
        <p>
          Equipment footage demonstrates a duty or process stage. It does not prove that the same
          flowsheet fits another orebody.
        </p>
        <a class="button" href="/assess-my-project/">Assess My Project</a>
      </aside>
    </div>
  </section>

  <ProjectCta />
</BaseLayout>

<style>
  .video-frame {
    position: relative;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-bottom: 42px;
    background: var(--charcoal);
  }

  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-fallback {
    margin-bottom: 42px;
    padding: 30px;
    border: 1px solid var(--line);
    background: var(--paper-deep);
  }
</style>
