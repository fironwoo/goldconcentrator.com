---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ProjectCta from '../components/ProjectCta.astro';

const factoryImages = [
  {
    src: '/images/factory/gold-trommel-workshop.webp',
    alt: 'Gold trommel feed hopper prepared in the factory workshop',
    title: 'Trommel feed section',
    caption: 'Workshop photo detail used to review feeding access, frame clearance and operating layout.',
  },
  {
    src: '/images/factory/rock-gold-field-installation.webp',
    alt: 'Rotary scrubber drive section prepared in the factory workshop',
    title: 'Drive and support detail',
    caption: 'Factory detail for checking drives, rollers, guards, access space and discharge interfaces.',
  },
  {
    src: '/images/factory/jig-machine-workshop.webp',
    alt: 'Jig concentrator body prepared in the factory workshop',
    title: 'Gravity circuit equipment',
    caption: 'Jig concentrator workshop detail for gravity recovery and heavy-mineral circuits.',
  },
  {
    src: '/images/factory/screen-loading-delivery.webp',
    alt: 'Mobile trommel frame and discharge area prepared in the factory workshop',
    title: 'Mobile plant detail',
    caption: 'Close workshop crop used to review equipment access, supports and connection points.',
  },
];
---

<BaseLayout
  title="Mineral Processing Equipment Manufacturing & Delivery"
  description="Equipment coordination, production review, quality checks, packing and export delivery from our Jiangxi factory and manufacturing base in China."
>
  <header class="page-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Manufacturing & Delivery' }]} />
      <span class="eyebrow">Our Jiangxi factory</span>
      <h1>Manufacturing & Delivery</h1>
      <p>
        The flowsheet defines the equipment duty. We then coordinate manufacturing, interfaces,
        checks, documentation, packing and export delivery around that duty.
      </p>
    </div>
  </header>
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div><span class="eyebrow">One accountable route</span><h2>Control the interfaces.</h2></div>
        <p>
          Many plant problems occur between machines: mismatched discharge heights, uncontrolled
          pumps, missing chutes, unsuitable motors or undocumented recirculating streams.
        </p>
      </div>
      <div class="card-grid">
        <article class="surface-card"><h3>Manufacturing review</h3><p>Confirm duty, materials, drives, interfaces and the approved technical scope before production.</p></article>
        <article class="surface-card"><h3>Quality checks</h3><p>Record agreed inspection points, dimensions, components and visible test conditions before packing.</p></article>
        <article class="surface-card"><h3>Packing & shipment</h3><p>Coordinate packing lists, container planning, markings and export documents with the delivery scope.</p></article>
      </div>
      <div class="factory-gallery-block">
        <div class="section-heading">
          <div><span class="eyebrow">Factory materials</span><h2>Real equipment, not catalog noise.</h2></div>
          <p>
            These authorized factory photos support the manufacturing story without turning the site
            into a public equipment price list.
          </p>
        </div>
        <div class="factory-gallery">
          {factoryImages.map((image) => (
            <figure>
              <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
              <figcaption>
                <strong>{image.title}</strong>
                <span>{image.caption}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </div>
  </section>
  <ProjectCta />
</BaseLayout>

<style>
  .factory-gallery-block {
    margin-top: 72px;
  }

  .factory-gallery {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .factory-gallery figure {
    overflow: hidden;
    margin: 0;
    border: 1px solid var(--line);
    background: rgba(255, 253, 248, 0.78);
    box-shadow: 0 8px 30px rgba(29, 28, 25, 0.05);
  }

  .factory-gallery img {
    width: 100%;
    aspect-ratio: 1.12;
    object-fit: cover;
  }

  .factory-gallery figcaption {
    display: grid;
    gap: 8px;
    padding: 18px;
  }

  .factory-gallery strong {
    font-family: var(--font-display);
    font-size: 1.45rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .factory-gallery span {
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .factory-gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 650px) {
    .factory-gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
