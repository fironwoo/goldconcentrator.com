---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCta from '../components/ProjectCta.astro';
import { getHomepageSolutionCards, getWhatsAppUrl, SITE } from '../lib/site';

const solutionCards = getHomepageSolutionCards();
const projects = (await getCollection('projects'))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 3);
const articles = (await getCollection('knowledge'))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Ore-Led Gold Processing & Gravity Concentration Solutions"
  description="Practical flowsheet design, gravity concentration testing, equipment coordination and delivery for 5-100 TPH gold, tin, tungsten and chrome projects."
>
  <section class="hero">
    <div class="hero-media" aria-hidden="true"></div>
    <div class="container hero-content">
      <span class="eyebrow">Gold processing and gravity concentration</span>
      <h1>The Right Equipment Starts With the Right Flowsheet.</h1>
      <p>
        We assess the ore, test the recovery route and coordinate the equipment around the
        flowsheet for practical 5–100 TPH mineral processing projects.
      </p>
      <div class="hero-actions">
        <a class="button" href="/assess-my-project/">Assess My Gold Project</a>
        <a class="button button--ghost" href="#solutions">Explore Solutions</a>
      </div>
      <div class="hero-human">
        <strong>A real person reviews every project message.</strong>
        <span>
          WhatsApp is fastest for photos and short videos. Send ore type, target TPH, feed size,
          country and what equipment you already have.
        </span>
        <a href={getWhatsAppUrl(SITE.whatsapp)}>Message us on WhatsApp: {SITE.whatsapp}</a>
      </div>
      <ul class="hero-proof" aria-label="Key capabilities">
        <li><strong>10+ years</strong><span>Core team experience</span></li>
        <li><strong>Ore-led</strong><span>Process before equipment</span></li>
        <li><strong>5–100 TPH</strong><span>Target project range</span></li>
      </ul>
    </div>
  </section>

  <section class="principle">
    <div class="container principle-grid">
      <span>01 / Our principle</span>
      <h2>A machine can be copied. A workable flowsheet has to be reasoned from the ore.</h2>
      <p>
        Clay content, liberation size, valuable mineral distribution, water conditions and project
        maturity all change the answer. We use those facts to define the route before selecting
        equipment.
      </p>
    </div>
  </section>

  <section class="section response-path">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Human review</span>
          <h2>What happens after you send a message.</h2>
        </div>
        <p>
          You are not dropped into an equipment catalog. A reviewer checks the ore facts first, then
          asks for the missing details before suggesting a practical route.
        </p>
      </div>
      <div class="response-grid">
        <article>
          <span>01</span>
          <h3>You send the rough facts</h3>
          <p>Ore type, country, target TPH, feed size, photos, videos and any test or assay notes.</p>
        </article>
        <article>
          <span>02</span>
          <h3>We ask the useful questions</h3>
          <p>Clay, water, power, existing equipment, project stage and the real reason the plant is needed.</p>
        </article>
        <article>
          <span>03</span>
          <h3>You get a route to discuss</h3>
          <p>Usually within one business day: likely flowsheet, missing data and equipment roles.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="solutions">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Mineral solutions</span>
          <h2>Start with your ore type.</h2>
        </div>
        <p>
          Gold is our primary focus. Tin, tungsten, chrome and other dense minerals are assessed
          through the same gravity concentration discipline.
        </p>
      </div>
      <div class="solution-grid">
        {solutionCards.map((solution, index) => (
          <a
            class:list={[
              'solution-card',
              `solution-card--${solution.category}`,
              { 'solution-card--primary': index < 2 },
            ]}
            href={`/solutions/${solution.slug}/`}
          >
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div>
              <small>{solution.category === 'gold' ? 'Primary gold route' : solution.category === 'more' ? 'Additional capability' : 'Gravity mineral'}</small>
              <h3>{solution.name}</h3>
              <p>{solution.summary}</p>
              <strong>View solution →</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="eyebrow">How we work</span>
          <h2>From project data to shipment.</h2>
        </div>
        <p>
          The level of detail grows with the project. Initial direction is free; detailed design,
          calculations and drawings are scoped separately and may be credited against an equipment
          order.
        </p>
      </div>
      <ol class="process">
        <li><span>01</span><h3>Assess</h3><p>Review the ore, capacity, location and project stage.</p></li>
        <li><span>02</span><h3>Test</h3><p>Use representative samples to check gravity response and losses.</p></li>
        <li><span>03</span><h3>Design</h3><p>Define the flowsheet, operating logic and equipment roles.</p></li>
        <li><span>04</span><h3>Coordinate</h3><p>Manage manufacturing, quality checks and project interfaces.</p></li>
        <li><span>05</span><h3>Deliver</h3><p>Prepare packing, documentation and export shipment.</p></li>
      </ol>
    </div>
  </section>

  <section class="testing section">
    <div class="container testing-grid">
      <div class="testing-visual" aria-hidden="true">
        <div class="ore-dot ore-dot--1"></div>
        <div class="ore-dot ore-dot--2"></div>
        <div class="ore-dot ore-dot--3"></div>
        <div class="testing-lines"></div>
        <span>Feed</span>
        <strong>Test</strong>
        <em>Concentrate</em>
      </div>
      <div>
        <span class="eyebrow">Testing before selection</span>
        <h2>Small test work can prevent an expensive wrong route.</h2>
        <p>
          Our stable in-house capability focuses on gravity test work and amenability screening.
          Flotation or leaching programs are coordinated only when the ore and project require them.
        </p>
        <a class="text-link" href="/testing-process-design/">How testing informs the flowsheet</a>
      </div>
    </div>
  </section>

  <section class="section projects">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Selected project patterns</span>
          <h2>Evidence without invented claims.</h2>
        </div>
        <p>
          These launch case studies are structured placeholders for your verified records. Replace
          the clearly marked sample facts with approved project evidence before public launch.
        </p>
      </div>
      <div class="card-grid">
        {projects.map((project) => (
          <article class="surface-card project-card">
            <ul class="meta-list">
              <li class="tag">{project.data.country}</li>
              <li class="tag">{project.data.capacity}</li>
            </ul>
            <h3>{project.data.title}</h3>
            <p>{project.data.description}</p>
            <a class="text-link" href={`/projects/${project.id}/`}>Read case structure</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section knowledge-preview">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Knowledge and field notes</span>
          <h2>Useful answers before a sales call.</h2>
        </div>
        <a class="text-link" href="/knowledge/">View all knowledge</a>
      </div>
      <div class="article-list">
        {articles.map((article, index) => (
          <a href={`/knowledge/${article.id}/`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div>
              <small>{article.data.category}</small>
              <h3>{article.data.title}</h3>
            </div>
            <b>→</b>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ProjectCta />
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 790px;
    overflow: hidden;
    color: var(--white);
    background: #151615;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(18, 18, 17, 0.98) 0%, rgba(18, 18, 17, 0.82) 42%, rgba(18, 18, 17, 0.2) 76%, rgba(18, 18, 17, 0.42) 100%),
      linear-gradient(0deg, rgba(18, 18, 17, 0.82), transparent 44%),
      url('/images/hero-gravity-plant.webp') center / cover;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 182px;
  }

  .hero h1 {
    max-width: 850px;
    font-size: clamp(4rem, 9vw, 8.2rem);
  }

  .hero p {
    max-width: 620px;
    margin: 28px 0;
    color: rgba(255, 253, 248, 0.72);
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-human {
    display: grid;
    max-width: 640px;
    gap: 8px;
    margin-top: 22px;
    padding: 18px 20px;
    border: 1px solid rgba(239, 197, 109, 0.26);
    background: rgba(25, 26, 25, 0.58);
    backdrop-filter: blur(8px);
  }

  .hero-human strong {
    color: var(--gold-light);
    font-family: var(--font-display);
    font-size: 1.45rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .hero-human span {
    color: rgba(255, 253, 248, 0.72);
    font-size: 0.9rem;
  }

  .hero-human a {
    width: fit-content;
    color: var(--white);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-human a:hover {
    color: var(--gold-light);
  }

  .hero-proof {
    display: flex;
    max-width: 760px;
    margin: 74px 0 0;
    padding: 22px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    list-style: none;
  }

  .hero-proof li {
    flex: 1;
    padding-right: 22px;
  }

  .hero-proof strong,
  .hero-proof span {
    display: block;
  }

  .hero-proof strong {
    color: var(--gold-light);
    font-family: var(--font-display);
    font-size: 1.5rem;
    text-transform: uppercase;
  }

  .hero-proof span {
    color: rgba(255, 253, 248, 0.55);
    font-size: 0.72rem;
  }

  .principle {
    color: var(--white);
    background: var(--copper);
  }

  .principle-grid {
    display: grid;
    grid-template-columns: 0.25fr 1.4fr 0.7fr;
    align-items: start;
    gap: 48px;
    padding-top: 45px;
    padding-bottom: 45px;
  }

  .principle span {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .principle h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    text-transform: uppercase;
  }

  .principle p {
    margin: 0;
    color: rgba(255, 253, 248, 0.94);
    font-size: 0.88rem;
  }

  .response-path {
    background:
      radial-gradient(circle at 12% 14%, rgba(211, 154, 56, 0.13), transparent 22%),
      var(--paper);
  }

  .response-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .response-grid article {
    min-height: 245px;
    padding: 28px;
    border: 1px solid var(--line);
    background: rgba(255, 253, 248, 0.78);
    box-shadow: 0 8px 30px rgba(29, 28, 25, 0.05);
  }

  .response-grid span {
    color: var(--copper);
    font-family: var(--font-display);
    font-size: 1.6rem;
  }

  .response-grid h3 {
    margin: 46px 0 12px;
    font-family: var(--font-display);
    font-size: 2.1rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .response-grid p {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .solution-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .solution-card {
    display: flex;
    min-height: 260px;
    flex-direction: column;
    justify-content: space-between;
    padding: 22px;
    border: 1px solid var(--line);
    background: rgba(255, 253, 248, 0.72);
    transition:
      color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }

  .solution-card--primary {
    min-height: 360px;
    grid-column: span 2;
    padding: 32px;
    color: var(--white);
    background:
      linear-gradient(140deg, rgba(211, 154, 56, 0.13), transparent 40%),
      var(--charcoal);
  }

  .solution-card:hover {
    color: var(--white);
    background: var(--copper);
    transform: translateY(-4px);
  }

  .solution-card > span {
    color: var(--gold);
    font-family: var(--font-display);
    font-size: 1.3rem;
  }

  .solution-card small {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .solution-card h3 {
    margin: 8px 0 12px;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 0.95;
    text-transform: uppercase;
  }

  .solution-card:not(.solution-card--primary) h3 {
    font-size: 2.1rem;
  }

  .solution-card p {
    color: var(--muted);
    font-size: 0.86rem;
  }

  .solution-card--primary p {
    color: rgba(255, 253, 248, 0.65);
  }

  .solution-card:hover p {
    color: rgba(255, 255, 255, 0.8);
  }

  .solution-card strong {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .process {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    margin: 0;
    padding: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    list-style: none;
  }

  .process li {
    min-height: 230px;
    padding: 26px 22px;
    border-right: 1px solid rgba(255, 255, 255, 0.16);
  }

  .process li:last-child {
    border-right: 0;
  }

  .process span {
    color: var(--gold);
    font-family: var(--font-display);
    font-size: 1.4rem;
  }

  .process h3 {
    margin: 55px 0 8px;
    font-family: var(--font-display);
    font-size: 1.8rem;
    text-transform: uppercase;
  }

  .process p {
    margin: 0;
    color: rgba(255, 253, 248, 0.58);
    font-size: 0.82rem;
  }

  .testing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 80px;
  }

  .testing h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5.6rem);
    line-height: 0.94;
    text-transform: uppercase;
  }

  .testing p {
    color: var(--muted);
  }

  .testing-visual {
    position: relative;
    min-height: 430px;
    overflow: hidden;
    border: 1px solid var(--line);
    background:
      radial-gradient(circle at 24% 36%, rgba(182, 111, 50, 0.2), transparent 4%),
      radial-gradient(circle at 64% 64%, rgba(211, 154, 56, 0.28), transparent 5%),
      linear-gradient(135deg, var(--paper-deep), #c8b69d);
  }

  .testing-visual::before,
  .testing-visual::after {
    position: absolute;
    width: 250px;
    height: 250px;
    border: 1px solid rgba(34, 35, 33, 0.2);
    border-radius: 50%;
    content: '';
  }

  .testing-visual::before {
    top: -80px;
    left: -60px;
    box-shadow: 0 0 0 42px rgba(34, 35, 33, 0.03);
  }

  .testing-visual::after {
    right: -40px;
    bottom: -110px;
    box-shadow: 0 0 0 42px rgba(211, 154, 56, 0.1);
  }

  .testing-visual span,
  .testing-visual strong,
  .testing-visual em {
    position: absolute;
    font-family: var(--font-display);
    font-style: normal;
    text-transform: uppercase;
  }

  .testing-visual span {
    top: 22px;
    left: 22px;
  }

  .testing-visual strong {
    top: 47%;
    left: 42%;
    font-size: 3.4rem;
  }

  .testing-visual em {
    right: 22px;
    bottom: 22px;
    color: #725022;
  }

  .testing-lines {
    position: absolute;
    inset: 70px;
    border: 2px dashed rgba(34, 35, 33, 0.24);
    transform: rotate(-10deg);
  }

  .ore-dot {
    position: absolute;
    z-index: 2;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ink);
  }

  .ore-dot--1 {
    top: 110px;
    left: 90px;
  }

  .ore-dot--2 {
    top: 220px;
    left: 230px;
    background: var(--copper);
  }

  .ore-dot--3 {
    right: 70px;
    bottom: 80px;
    width: 36px;
    height: 36px;
    background: var(--gold);
  }

  .project-card h3 {
    margin-top: 28px;
  }

  .knowledge-preview {
    background: var(--paper-deep);
  }

  .article-list {
    border-top: 1px solid var(--line);
  }

  .article-list a {
    display: grid;
    grid-template-columns: 60px 1fr 40px;
    align-items: center;
    gap: 24px;
    padding: 26px 0;
    border-bottom: 1px solid var(--line);
  }

  .article-list > a > span {
    color: var(--copper);
    font-family: var(--font-display);
    font-size: 1.3rem;
  }

  .article-list small {
    color: var(--muted);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .article-list h3 {
    margin: 5px 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    line-height: 1;
    text-transform: uppercase;
  }

  .article-list b {
    font-size: 1.6rem;
    transition: transform 160ms ease;
  }

  .article-list a:hover b {
    transform: translateX(6px);
  }

  @media (max-width: 900px) {
    .principle-grid,
    .testing-grid {
      grid-template-columns: 1fr;
    }

    .solution-grid {
      grid-template-columns: 1fr 1fr;
    }

    .response-grid {
      grid-template-columns: 1fr;
    }

    .process {
      grid-template-columns: 1fr 1fr;
    }

    .process li:nth-child(even) {
      border-right: 0;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 790px;
    }

    .hero-media {
      background:
        linear-gradient(rgba(18, 18, 17, 0.84), rgba(18, 18, 17, 0.92)),
        url('/images/hero-gravity-plant.webp') 67% center / cover;
    }

    .hero-proof {
      gap: 18px;
      flex-direction: column;
      margin-top: 46px;
    }

    .hero-human {
      padding: 16px;
    }

    .principle-grid {
      gap: 20px;
    }

    .solution-grid,
    .process {
      grid-template-columns: 1fr;
    }

    .solution-card--primary {
      min-height: 320px;
      grid-column: span 1;
    }

    .process li,
    .process li:nth-child(even) {
      min-height: auto;
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.16);
    }

    .process h3 {
      margin-top: 20px;
    }
  }
</style>
